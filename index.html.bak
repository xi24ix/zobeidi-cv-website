o-cid-iyt52rsq data-astro-transition-scope="astro-zdgos5s3-1"> <div class="horizontal-transition-row" data-transition-row style="--row-index: 0;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 1;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 2;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 3;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 4;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 5;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 6;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 7;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 8;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 9;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 10;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div><div class="horizontal-transition-row" data-transition-row style="--row-index: 11;" data-astro-cid-iyt52rsq> <div class="horizontal-transition-row-inner" data-astro-cid-iyt52rsq></div> </div> </div>  <script type="module" src="_astro/HorizontalTransition.astro_astro_type_script_index_0_lang.BNxDT9V3.js"></script> <!-- transition:animate="none" prevents default morph that caused reload flash on project→lab --><div class="lab-vertical-transition" data-lab-vertical-transition data-astro-transition-persist="lab-vertical-transition" data-astro-cid-z245yfbr data-astro-transition-scope="astro-kdvmkbyp-2"> <div class="lab-vertical-transition-col" data-transition-col style="--col-index: 0;" data-astro-cid-z245yfbr> <div class="lab-vertical-transition-col-inner" data-astro-cid-z245yfbr></div> </div><div class="lab-vertical-transition-col" data-transition-col style="--col-index: 1;" data-astro-cid-z245yfbr> <div class="lab-vertical-transition-col-inner" data-astro-cid-z245yfbr></div> </div><div class="lab-vertical-transition-col" data-transition-col style="--col-index: 2;" data-astro-cid-z245yfbr> <div class="lab-vertical-transition-col-inner" data-astro-cid-z245yfbr></div> </div><div class="lab-vertical-transition-col" data-transition-col style="--col-index: 3;" data-astro-cid-z245yfbr> <div class="lab-vertical-transition-col-inner" data-astro-cid-z245yfbr></div> </div><div class="lab-vertical-transition-col" data-transition-col style="--col-index: 4;" data-astro-cid-z245yfbr> <div class="lab-vertical-transition-col-inner" data-astro-cid-z245yfbr></div> </div><div class="lab-vertical-transition-col" data-transition-col style="--col-index: 5;" data-astro-cid-z245yfbr> <div class="lab-vertical-transition-col-inner" data-astro-cid-z245yfbr></div> </div> </div>   <script type="module" src="_astro/LabVerticalTransition.astro_astro_type_script_index_0_lang.hQNXqDFK.js"></script>  </div> <div id="video-footer-section" class="video-footer-section">
  <div class="video-footer-sticky">
    <div id="video-footer-rect" class="video-footer-rect">
      <video
        id="video-footer-video"
        class="video-footer-video"
        src="zobeidi-fish-higgs.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      ></video>
      <!-- In-video overlay: logo + copyright, fades in when rect is fully expanded -->
      <div id="video-footer-overlay" class="video-footer-overlay" aria-hidden="true">
        <img src="dh-logo.svg" alt="Hossein J Zobeidi" class="video-footer-overlay__logo" aria-label="Hossein J Zobeidi">
        <span class="video-footer-overlay__copy">&copy; 2026 Hossein J Zobeidi</span>
      </div>
    </div>
  </div>
</div>

<style>
  /* =========================================================
     VIDEO FOOTER — Scroll-based expanding rectangle
     Starting size: ~58 % vw × 62 % vh (25 % bigger than before)
     Ending size:   100 vw × 100 vh
     Copyright/logo appear inside once fully expanded
     ========================================================= */
  .video-footer-section {
    position: relative;
    height: 300vh;
    z-index: 0;
  }

  .video-footer-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
  }

  .video-footer-rect {
    position: relative;
    will-change: width, height, border-radius;
    overflow: hidden;
    /* initial size — 25 % bigger than the original 33 × 50 → ~58 vw × 62 vh */
    width: 58vw;
    height: 62vh;
    border-radius: 16px;
  }

  .video-footer-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  /* ── In-video copyright overlay ──────────────────────────── */
  .video-footer-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 28px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 5;
    /* subtle gradient so text stays legible over any video frame */
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    pointer-events: none;
  }

  .video-footer-overlay.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .video-footer-overlay__logo {
    width: 52px;
    height: auto;
    fill: #fff;
  }

  .video-footer-overlay__copy {
    font-family: "Alumni Sans", "Inter", sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }
</style>

<script>
  (function () {
    var section  = document.getElementById('video-footer-section');
    var rect     = document.getElementById('video-footer-rect');
    var overlay  = document.getElementById('video-footer-overlay');

    if (!section || !rect) return;

    var RAF = null;

    function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

    /* cubic ease-in-out */
    function ease(t) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function lerp(a, b, t) { return a + (b - a) * t; }

    function onScroll() {
      if (RAF) return;
      RAF = requestAnimationFrame(update);
    }

    function update() {
      RAF = null;

      var sectionTop    = section.getBoundingClientRect().top + window.scrollY;
      var sectionHeight = section.offsetHeight;
      var vh            = window.innerHeight;

      var scrolled  = window.scrollY - sectionTop;
      var progress  = clamp(scrolled / (sectionHeight - vh), 0, 1);
      /* Compress expansion into the first 70 % of scroll — feels ~43 % snappier.
         The rect then stays full-screen for the remaining scroll distance,
         giving the copyright overlay time to be appreciated. */
      var expansionProgress = clamp(progress / 0.70, 0, 1);
      var t         = ease(expansionProgress);

      /* ── sizes — start 25 % bigger (58 × 62) → full (100 × 100) ── */
      var w = lerp(58,  100, t);   /* vw */
      var h = lerp(62,  100, t);   /* vh */
      var r = lerp(16,    0, t);   /* border-radius px */

      rect.style.width        = w + 'vw';
      rect.style.height       = h + 'vh';
      rect.style.borderRadius = r + 'px';

      /* show overlay only when rect is ≥ 97 % expanded */
      if (overlay) {
        if (progress >= 0.65) {
          overlay.classList.add('is-visible');
        } else {
          overlay.classList.remove('is-visible');
        }
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  })();
</script>

