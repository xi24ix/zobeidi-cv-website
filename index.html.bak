      (function () {
        function addTransitionExclusionClasses(e) {
          var target = e.target;
          if (!target || !target.closest) return;
          var link = target.closest('a[href]');
          var inCarousel = target.closest('[data-carousel]');
          var pathname = window.location.pathname.replace(/\/$/, '') || '/';
          var isHome = pathname === '' || pathname === '/' || pathname === '/index.html';
          if (link && link.href) {
            try {
              var url = new URL(link.href, window.location.origin);
              if (
                url.origin === window.location.origin &&
                url.protocol !== 'javascript:' &&
                url.protocol !== 'mailto:'
              ) {
                var path = url.pathname.replace(/\/$/, '') || '/';
                var is404Page = !!document.querySelector('[data-page="404"]');
                if (
                  is404Page ||
                  path === '/' ||
                  path.indexOf('/work/') === 0 ||
                  path.indexOf('/lab') === 0
                ) {
                  document.documentElement.classList.add(
                    'custom-page-transition',
                    'lab-vertical-transition-active'
                  );
                  return;
                }
              }
            } catch (_) {}
          }
          if (isHome && inCarousel) {
            document.documentElement.classList.add(
              'custom-page-transition',
              'lab-vertical-transition-active'
            );
          }
        }
        document.addEventListener('pointerdown', addTransitionExclusionClasses, true);
        document.addEventListener('touchstart', addTransitionExclusionClasses, {
          capture: true,
          passive: true,
        });
      })();
