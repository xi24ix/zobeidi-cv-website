      (function () {
        function measure() {
          var el = document.createElement('div');
          el.style.cssText =
            'position:fixed;top:0;left:0;width:0;pointer-events:none;visibility:hidden;z-index:-1';
          document.body.appendChild(el);
          el.style.height = '100lvh';
          var h1 = el.offsetHeight;
          el.style.height = '100vh';
          var h2 = el.offsetHeight;
          el.style.height = '100dvh';
          var h3 = el.offsetHeight;
          el.remove();
          return Math.max(h1, h2, h3, window.innerHeight, document.documentElement.clientHeight);
        }
        var w = window.innerWidth;
        document.documentElement.style.setProperty('--stable-vh', measure() + 'px');
        window.addEventListener('resize', function () {
          if (window.innerWidth !== w) {
            w = window.innerWidth;
            document.documentElement.style.setProperty('--stable-vh', measure() + 'px');
          }
        });
      })();
    </script> <script>
      history.scrollRestoration = 'manual';
      function scrollToTop() {
        window.scrollTo(0, 0);
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
      }
      scrollToTop();
      document.addEventListener('DOMContentLoaded', scrollToTop);
      window.addEventListener('load', scrollToTop);
      window.addEventListener('pageshow', function (e) {
        if (!e.persisted) scrollToTop();
      });
